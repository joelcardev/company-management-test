# Environment variables declared in this file are automatically made available to Prisma.

# Connects to the local docker-compose PostgreSQL instance
DATABASE_URL="postgresql://root:rootpassword@localhost:5432/company_management?schema=public"

# Configuração de Notificação por E-mail
# Deixe EMAIL_USER vazio para usar o Ethereal Mail (mock automático para desenvolvimento)
EMAIL_HOST="smtp.ethereal.email"
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# Lista de destinatários das notificações de novas empresas (separados por vírgula)
EMAIL_RECIPIENTS="admin@empresa.com,gerencia@empresa.com"

# Limite de tentativas de envio de e-mail antes de marcar como falha permanente
EMAIL_MAX_ATTEMPTS=3
